# .env.example — copie para .env para desenvolvimento local
  # NUNCA commite o .env real

  # Opcao 1: variaveis separadas
  DB_HOST=localhost
  DB_PORT=5432
  DB_NAME=carteirinha_db
  DB_USER=carteirinha_user
  DB_PASSWORD=carteirinha_pass
  DB_SSL=false

  # Opcao 2: DATABASE_URL (substitui todas as DB_* acima)
  # DATABASE_URL=postgresql://carteirinha_user:carteirinha_pass@localhost:5432/carteirinha_db

  PORT=3300
  NODE_ENV=development
  